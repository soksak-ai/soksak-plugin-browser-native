{
  "name": "soksak-plugin-browser-native",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "description": "soksak browser plugin — native child webview rendered as a content view",
  "scripts": {
    "build": "node build.mjs",
    "dev": "node build.mjs --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npx --yes soksak-plugin-doctor .",
    "test": "vitest run"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "esbuild": "^0.24.2",
    "soksak-kit-browser-common": "github:soksak-ai/soksak-kit-browser-common",
    "typescript": "~5.9.3",
    "vitest": "^2.1.8"
  },
  "soksakRelease": {
    "kind": "plugin",
    "id": "soksak-plugin-browser-native",
    "repository": "https://github.com/soksak-ai/soksak-plugin-browser-native",
    "manifest": "release.json"
  }
}
