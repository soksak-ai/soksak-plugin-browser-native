{
  "spec": "soksak-spec-plugin@0.0.1",
  "id": "soksak-plugin-browser-native",
  "name": {
    "ko": "\ube0c\ub77c\uc6b0\uc800 (Webview)",
    "en": "Browser (Webview)"
  },
  "version": "0.0.1",
  "description": {
    "ko": "\ucf58\ud150\uce20 \ubdf0\ub85c \ube0c\ub77c\uc6b0\uc800\ub97c \ub80c\ub354 \u2014 \ucf54\uc5b4 \ub124\uc774\ud2f0\ube0c child webview(OS \uc6f9\ubdf0) \ub97c \uc9c1\uc811 \uad6c\ub3d9. URL \ubc14\u00b7\uc990\uaca8\ucc3e\uae30\u00b7\ubd81\ub9c8\ud06c\u00b7devtools \ud1a0\uae00 \ub0b4\uc7a5.",
    "en": "Renders the browser as a content view \u2014 drives the core native child webview (OS webview) directly. Built-in URL bar, bookmarks, and devtools toggle."
  },
  "entry": "main.js",
  "implements": [
    {
      "id": "soksak-spec-plugin-browser",
      "version": "0.0.1"
    }
  ],
  "permissions": [
    "ui",
    "commands",
    "programs",
    "webview",
    "network",
    "data"
  ],
  "configuration": [
    {
      "key": "homeUrl",
      "type": "string",
      "default": "about:blank",
      "title": {
        "ko": "\uc2dc\uc791 URL",
        "en": "Start URL"
      },
      "description": {
        "ko": "\uc0c8 \ube0c\ub77c\uc6b0\uc800 \ud0ed\uc774 \ucc98\uc74c \uc5ec\ub294 \uc8fc\uc18c.",
        "en": "Address a new browser tab opens to."
      }
    },
    {
      "key": "browserNewWindow",
      "type": "enum",
      "enum": [
        "tab",
        "window"
      ],
      "enumLabels": [
        {
          "ko": "\uc0c8 \ud0ed",
          "en": "New tab"
        },
        {
          "ko": "\uc0c8 \ucc3d",
          "en": "New window"
        }
      ],
      "default": "tab",
      "title": {
        "ko": "\uc0c8 \ub9c1\ud06c \uc5f4\uae30",
        "en": "Open new links in"
      },
      "description": {
        "ko": "target=_blank / window.open \uc0c8 \ub9c1\ud06c\ub97c \uc0c8 \ud0ed(\uc571 \ub0b4 \ube0c\ub77c\uc6b0\uc800 \ubdf0) \ub610\ub294 \ub3c5\ub9bd OS \ucc3d\uc73c\ub85c \uc5f0\ub2e4.",
        "en": "Open target=_blank / window.open links as a new tab (in-app browser view) or an independent OS window."
      }
    }
  ],
  "contributes": {
    "views": [
      {
        "id": "content",
        "title": {
          "ko": "\ube0c\ub77c\uc6b0\uc800 (Webview)",
          "en": "Browser (Webview)"
        },
        "icon": "\ud83c\udf10",
        "placements": [
          "content"
        ],
        "defaultPlacement": "content",
        "transparent": true,
        "nativeSurface": true,
        "status": [
          "busy",
          "ready"
        ]
      }
    ],
    "programs": [
      {
        "id": "browser",
        "path": {
          "ko": "\ube0c\ub77c\uc6b0\uc800",
          "en": "Browser"
        },
        "title": {
          "ko": "Webview",
          "en": "Webview"
        },
        "kind": "view",
        "view": "content"
      }
    ],
    "commands": [
      {
        "name": "ping",
        "title": {
          "ko": "\ud50c\ub7ec\uadf8\uc778 \uc801\uc7ac/\ubc84\uc804 \ud655\uc778(E2E)",
          "en": "Ping (load/version check)"
        }
      },
      {
        "name": "navigate",
        "title": {
          "ko": "URL \uc774\ub3d9",
          "en": "Navigate to URL"
        }
      },
      {
        "name": "back",
        "title": {
          "ko": "\uc774\uc804 \ud398\uc774\uc9c0",
          "en": "Go Back"
        }
      },
      {
        "name": "forward",
        "title": {
          "ko": "\ub2e4\uc74c \ud398\uc774\uc9c0",
          "en": "Go Forward"
        }
      },
      {
        "name": "reload",
        "title": {
          "ko": "\uc0c8\ub85c\uace0\uce68",
          "en": "Reload"
        }
      },
      {
        "name": "open",
        "title": {
          "ko": "\ube0c\ub77c\uc6b0\uc800 \ubdf0 \uc5f4\uae30",
          "en": "Open browser view"
        }
      },
      {
        "name": "devtools",
        "title": {
          "ko": "\uac1c\ubc1c\uc790 \ub3c4\uad6c \ud1a0\uae00",
          "en": "Toggle devtools"
        }
      },
      {
        "name": "list",
        "title": {
          "ko": "\ube0c\ub77c\uc6b0\uc800 webview \ubaa9\ub85d",
          "en": "List browser webviews"
        }
      },
      {
        "name": "eval",
        "title": {
          "ko": "JS \uc2e4\ud589",
          "en": "Evaluate JS"
        },
        "danger": "inject"
      },
      {
        "name": "dom.text",
        "title": {
          "ko": "DOM \ud14d\uc2a4\ud2b8 \uc77d\uae30",
          "en": "Get DOM text"
        }
      },
      {
        "name": "dom.html",
        "title": {
          "ko": "DOM HTML \uc77d\uae30",
          "en": "Get DOM HTML"
        }
      },
      {
        "name": "dom.query",
        "title": {
          "ko": "DOM \uc694\uc18c \uc870\ud68c",
          "en": "Query DOM elements"
        }
      },
      {
        "name": "dom.click",
        "title": {
          "ko": "DOM \ud074\ub9ad",
          "en": "Click DOM element"
        },
        "danger": "inject"
      },
      {
        "name": "dom.fill",
        "title": {
          "ko": "DOM \uc785\ub825 \ucc44\uc6b0\uae30",
          "en": "Fill DOM input"
        },
        "danger": "inject"
      },
      {
        "name": "dom.submit",
        "title": {
          "ko": "\ud3fc \uc81c\ucd9c",
          "en": "Submit form"
        },
        "danger": "inject"
      },
      {
        "name": "dom.wait-for",
        "title": {
          "ko": "\uc694\uc18c \ub300\uae30",
          "en": "Wait for element"
        }
      },
      {
        "name": "media.sniff",
        "title": {
          "ko": "\ubbf8\ub514\uc5b4 \uc2a4\ub2c8\ud504",
          "en": "Sniff media URLs"
        },
        "danger": "inject"
      },
      {
        "name": "media.extract",
        "title": {
          "ko": "\ubbf8\ub514\uc5b4 \ucd94\ucd9c(\uc624\ud504\uc2a4\ud06c\ub9b0)",
          "en": "Extract media (offscreen)"
        },
        "danger": "inject"
      },
      {
        "name": "home",
        "title": {
          "ko": "\ud648",
          "en": "Home"
        }
      }
    ],
    "nodes": [
      {
        "id": "urlbar",
        "description": {
          "ko": "URL \uc785\ub825\ucc3d",
          "en": "URL input bar"
        }
      },
      {
        "id": "back",
        "description": {
          "ko": "\uc774\uc804 \ubc84\ud2bc",
          "en": "Back button"
        }
      },
      {
        "id": "forward",
        "description": {
          "ko": "\ub2e4\uc74c \ubc84\ud2bc",
          "en": "Forward button"
        }
      },
      {
        "id": "reload",
        "description": {
          "ko": "\uc0c8\ub85c\uace0\uce68 \ubc84\ud2bc",
          "en": "Reload button"
        }
      },
      {
        "id": "devtools",
        "description": {
          "ko": "\uac1c\ubc1c\uc790 \ub3c4\uad6c \ubc84\ud2bc",
          "en": "Developer tools button"
        }
      },
      {
        "id": "freeze",
        "description": {
          "ko": "\ub514\ubc14\uc774\ub354 \ub4dc\ub798\uadf8 \uc911 \uc2dc\uac01 \uc5f0\uc18d \uc2a4\ud0e0\ub4dc\uc778(freeze-frame) \uc624\ubc84\ub808\uc774",
          "en": "Visual-continuity stand-in (freeze-frame) overlay during divider drag"
        }
      },
      {
        "id": "home",
        "description": {
          "ko": "\ud648",
          "en": "Home"
        }
      }
    ]
  }
}
